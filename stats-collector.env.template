# SRT Stats Collector Configuration
#
# Install to: /etc/srt-live-server/stats-collector.env
#
# Optional: API key for stats endpoint authentication
#SRT_API_KEY=your-api-key-here

# Polling interval in seconds (default: 1)
#POLL_INTERVAL=1

# Output file path (default: /tmp/srt-overlay.txt)
#OVERLAY_FILE=/tmp/srt-overlay.txt
