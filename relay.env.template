# SRT-to-RTMP Relay Configuration
#
# Copy this file for each platform and fill in the stream key:
#   /etc/srt-live-server/relay-twitch.env
#   /etc/srt-live-server/relay-youtube.env
#
# File permissions MUST be 0600 owned by root:srt
#
# SRT input (from srt_server player port)
SRT_INPUT="srt://127.0.0.1:4000?streamid=play/live/feed1&mode=caller"

# RTMP output URL (without stream key)
RTMP_URL="rtmp://example.com/live"

# Stream key (keep secret!)
STREAM_KEY="your-stream-key-here"
